# Anthropic API Key (Required)
# Get your API key from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Discord Bot Configuration (Required for Discord Bot)
# Create a bot at: https://discord.com/developers/applications
# 1. Create a new application
# 2. Go to "Bot" section and create a bot
# 3. Copy the bot token
# 4. Enable "Message Content Intent" in Bot settings
# 5. Invite bot using OAuth2 URL with "bot" scope and "Send Messages", "Read Messages" permissions
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Notion API Configuration (Required for Notion Agent)
# Get your API key from: https://www.notion.so/my-integrations
NOTION_API_KEY=your_notion_api_key_here

# Get your database ID from the Notion database URL
# Example: https://www.notion.so/myworkspace/{DATABASE_ID}?v=...
NOTION_DATABASE_ID=your_notion_database_id_here

# Email Configuration (Optional - for sending job application emails)
# SMTP Server Settings - Choose based on your email provider:

# For Gmail:
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# Note: Gmail requires App Password (not regular password)
# Enable 2FA first, then generate app password at: https://myaccount.google.com/apppasswords

# For Outlook/Hotmail:
# SMTP_SERVER=smtp-mail.outlook.com
# SMTP_PORT=587

# For Yahoo:
# SMTP_SERVER=smtp.mail.yahoo.com
# SMTP_PORT=587

# For custom SMTP server:
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# Your email credentials
SENDER_EMAIL=your_email@gmail.com
SENDER_PASSWORD=your_app_password_here

# Where to receive job application emails
RECIPIENT_EMAIL=your_email@gmail.com

# Job Search Preferences (Optional - can be set in user_data/preferences.json instead)
DEFAULT_SEARCH_TERM=software engineer
DEFAULT_LOCATION=San Francisco, CA
DEFAULT_RESULTS_WANTED=20
DEFAULT_HOURS_OLD=72

# Auto Job Monitoring (Optional - for Discord bot)
# Enable automatic job checking every N minutes
ENABLE_AUTO_JOB_MONITOR=false
JOB_CHECK_INTERVAL_MINUTES=30
